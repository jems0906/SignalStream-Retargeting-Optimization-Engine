# Environment Variables for Real-Time Retargeting Service

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Server Configuration 
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
SERVER_RELOAD=false

# Processing Configuration
MAX_EVENTS_PER_USER=1000
MAX_USER_HISTORY_EVENTS=50
MAX_SIGNALS_PER_USER=100
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL=1.0

# Audience Thresholds
CART_ABANDONMENT_HOURS=24
VIDEO_COMPLETION_THRESHOLD=0.75
HIGH_INTENT_THRESHOLD=0.7